# =============================================================================
# White Salary - Git忽略规则
# 2026-07-03 开源准备（批7）：全面加固，确保 clone 上传时不带任何机密/隐私/大文件。
# 原则：源码 + 模板(.example/.default) 进仓库；真实密钥、登录态、用户数据、
#       第三方软件、不可分发素材和用户私有数据一律排除。程序首次运行会自动重建 data/ 等目录。
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# --- 虚拟环境 ---
.venv/
venv/
env/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- 日志（整个目录，运行时自动生成）---
logs/
*.log

# --- 模型文件（太大了不提交到Git）---
models/**/*.pth
models/**/*.bin
models/**/*.onnx
models/**/*.pt

# =============================================================================
# 机密 / 隐私（绝不能进仓库）
# =============================================================================

# --- 用户主配置（含所有LLM的API密钥）：只提交 conf.default.yaml 模板 ---
# 2026-07-03 开源准备（批7）：clone 后复制 conf.default.yaml -> conf.yaml 再填 key
conf.yaml

# --- test_apis.py / test_futureppo.py 用的真实密钥：只提交 providers.example.json ---
# 2026-07-03 开源准备（批7）：复制 scripts/providers.example.json -> scripts/providers.json 再填
scripts/providers.json

# --- 插件市场 GitHub 配置（含 token + admin_password）：只提交 .example 模板 ---
# 2026-07-03 开源准备（批7）：复制 config/github_config.example.json -> config/github_config.json 再填
config/github_config.json

# --- 开发者账号库（含密码哈希 + 登录 token）：由程序首次运行自动生成，不提交 ---
config/developers.json

# --- B站登录态（sessdata/bili_jct 等 cookie）：由扫码登录/设置面板自动写入，不提交 ---
config/bili.ini

# --- QQ空间登录态（skey/p_skey cookie）：由设置面板自动写入，不提交 ---
config/qzone.ini

# --- 兜底：任何 cookie 文件、任何本地私有配置 ---
config/*_cookie*
config/*.local.*
white-salary.service
*.cookie
*.cookies

# =============================================================================
# 用户运行时数据（隐私 + 会不断变大；程序会按需自动重建 data/ 下各子目录：
#   affinity 好感度 / qq 聊天 / memory 记忆 / chat_history 历史 / cache 缓存 等）
# =============================================================================
data/

# =============================================================================
# 第三方软件 / 登录态 / 大体积目录（不应随源码分发）
# =============================================================================

# --- NapCat（QQ机器人框架，第三方软件 + 登录态，体积上 GB）---
NapCat/
NapCat_OneKey/

# --- 前端依赖（npm install 自动装）---
frontend/node_modules/
node_modules/

# =============================================================================
# 版权素材（参考音频不随源码分发；见开源风险说明）
# =============================================================================

# --- Live2D 模型 ---
# live2d_models/ 下的公开可分发模型随源码提供，方便新手开箱即用。
# 仅忽略用户自行添加的私有素材；当前默认模型保持入库。

# --- TTS 参考音频（音色版权，用户自备）---
assets/tts/*.wav
assets/tts/*.mp3

# --- 根目录测试音频（开发期产物：test_tts_siliconflow*.mp3 / test_ws_audio.mp3 等）---
/*.mp3
/*.wav
test_tts_*.mp3
test_ws_audio.mp3

# =============================================================================
# 白的人设（用户的私人创作，2026-07-03 用户拍板：保持私有，不随仓库公开）
# 仓库内提供 prompts/system_prompt.example.txt 通用示例，clone 用户复制改名后
# 写自己的角色即可（cp prompts/system_prompt.example.txt prompts/system_prompt.txt）
# =============================================================================
prompts/system_prompt.txt

# =============================================================================
# 备份 / 快照（含历史密钥快照，是本地安全网，绝不进仓库）
# =============================================================================
backups/
prompts/backups/

# --- 临时工作目录 ---
scratchpad/
data/temp/

# --- 系统文件 ---
.DS_Store
Thumbs.db

# --- 测试缓存 ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# --- Claude Code 助手本地配置（个人开发环境，不进仓库）---
.claude/

# =============================================================================
# 内部工作文档（含作者个人信息/私聊分析/人设细节，2026-07-03 公开前移出仓库、留本地）
# 这些是审计与开发过程的内部记录，对作者有价值但不适合公开分发；
# 公开的版本历史见 CHANGELOG.md
# =============================================================================
PROJECT_PLAN.md
PROJECT_PLAN.legacy-2026-04.md
PROJECT_AUDIT_2026-07-02.md
docs/PANEL_AUDIT_2026-07-03.md
docs/audit-2026-07-02/
docs/panel-audit-2026-07-03/
